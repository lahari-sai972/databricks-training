#WITHCOLUMN
from pyspark.sql.functions import *
# Create bonus column as 10% of salary
display(df.withColumn("bonus", df.salary * 0.10))
# Create annual_salary column
display(df.withColumn("annual_salary", df.salary * 12))
# Create tax column as 5% of salary
display(df.withColumn("tax", df.salary * 0.05))
# Create updated_salary by adding 5000
display(df.withColumn("updated_salary", df.salary + 5000))
# Create salary_category column
display(df.withColumn("salary_category", when(df.salary > 80000, "High").when(df.salary >= 50000, "Medium").otherwise("Low")))
# Create age_group column
display(df.withColumn("age_group", when(df.age < 25, "Young").otherwise("Adult")))
# Create location column by combining city and department
display(df.withColumn("location", concat(col("city"), lit(" - "), col("department"))))
# Create increment_salary column with 15% hike
display(df.withColumn("increment_salary", df.salary * 1.15))
# Create experience_status column based on joining year
display(df.withColumn("experience_status", when(year("joining_date") < 2022, "Experienced").otherwise("Fresher")))
# Create name_length column using employee name
display(df.withColumn("name_length", length(col("emp_name"))))
# Create is_high_salary column using condition
display(df.withColumn("is_high_salary", when(df.salary > 70000, "Yes").otherwise("No")))
# Create joining_year column from joining_date
display(df.withColumn("joining_year", year(col("joining_date"))))
# Create salary_after_tax column
display(df.withColumn("salary_after_tax", df.salary - (df.salary * 0.05)))
# Create department_code column
display(df.withColumn("department_code", substring(col("department"), 1, 3)))
# Create double_salary column
display(df.withColumn("double_salary", df.salary * 2))
     
