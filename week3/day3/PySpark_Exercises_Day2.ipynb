#SORT / ORDERBY
from pyspark.sql.functions import *
# Sort employees by salary ascending
display(df.orderBy("salary"))
# Sort employees by salary descending
display(df.orderBy(col("salary").desc()))
# Sort employees by age descending
display(df.orderBy(col("age").desc()))
# Sort employees by emp_name ascending
display(df.orderBy("emp_name"))
# Sort employees by city and salary descending
display(df.orderBy("city", col("salary").desc()))
# Sort employees by joining_date
display(df.orderBy("joining_date"))
# Sort employees by department
display(df.orderBy("department"))
# Sort employees by designation descending
display(df.orderBy(col("designation").desc()))
# Sort employees first by city then age
display(df.orderBy("city", "age"))
# Sort employees by salary and limit top 10
display(df.orderBy(col("salary").desc()).limit(10))
# Sort employees by emp_id descending
display(df.orderBy(col("emp_id").desc()))
# Sort employees from IT department by salary descending
display(df.filter(df.department == "IT").orderBy(col("salary").desc()))
# Sort employees by joining_date descending
display(df.orderBy(col("joining_date").desc()))
# Sort employees alphabetically by emp_name
display(df.orderBy("emp_name"))
# Sort employees by multiple columns
display(df.orderBy("department", col("salary").desc()))
     
