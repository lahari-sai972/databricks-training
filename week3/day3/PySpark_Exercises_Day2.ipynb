# SELECT
# Select only emp_name and salary
display(
    df.select("emp_name", "salary")
)
# Select emp_id, emp_name, and department
display(
    df.select("emp_id", "emp_name", "department")
)
# Select city, designation, and salary
display(
    df.select("city", "designation", "salary")
)
# Select all employees from only IT department with selected columns
display(
    df.filter(df.department == "IT")
      .select("emp_name", "designation", "salary", "department")
)
# Select emp_name, joining_date, and salary
display(
    df.select("emp_name", "joining_date", "salary")
)
# Select first 5 columns from dataframe
display(
    df.select("emp_id", "emp_name", "age", "city", "designation")
)
# Select employees whose salary column only
display(
    df.select("salary")
)
# Select emp_name and city for employees from Hyderabad
display(
    df.filter(df.city == "Hyderabad")
      .select("emp_name", "city")
)
# Select designation and department
display(
    df.select("designation", "department")
)
# Select all columns except joining_date
display(
    df.drop("joining_date")
)
     
