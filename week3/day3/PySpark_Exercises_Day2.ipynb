from pyspark.sql.functions import *
# Display emp_name as employee_name
display(df.select(col("emp_name").alias("employee_name")))
# Display salary as monthly_salary
display(df.select(col("salary").alias("monthly_salary")))
# Display department as dept
display(df.select(col("department").alias("dept")))
# Display joining_date as doj
display(df.select(col("joining_date").alias("doj")))
# Select emp_name as name and city as location
display(df.select(col("emp_name").alias("name"), col("city").alias("location")))
# Display designation as job_role
display(df.select(col("designation").alias("job_role")))
# Display age as employee_age
display(df.select(col("age").alias("employee_age")))
# Select multiple columns using aliases
display(df.select(col("emp_id").alias("id"), col("emp_name").alias("name"), col("salary").alias("income")))
# Display salary as emp_salary and department as emp_dept
display(df.select(col("salary").alias("emp_salary"), col("department").alias("emp_dept")))
# Display city as work_location
display(df.select(col("city").alias("work_location")))
     
