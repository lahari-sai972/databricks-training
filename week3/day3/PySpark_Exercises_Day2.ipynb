#TYPECASTING
from pyspark.sql.functions import *
# Convert salary to string datatype
display(df.withColumn("salary", col("salary").cast("string")))
# Convert age to double datatype
display(df.withColumn("age", col("age").cast("double")))
# Convert joining_date to date datatype
display(df.withColumn("joining_date", col("joining_date").cast("date")))
# Convert emp_id to string datatype
display(df.withColumn("emp_id", col("emp_id").cast("string")))
# Convert salary to integer datatype
display(df.withColumn("salary", col("salary").cast("int")))
# Convert age to string datatype
display(df.withColumn("age", col("age").cast("string")))
# Convert joining_date to timestamp datatype
display(df.withColumn("joining_date", col("joining_date").cast("timestamp")))
# Convert salary to float datatype
display(df.withColumn("salary", col("salary").cast("float")))
# Convert emp_id to long datatype
display(df.withColumn("emp_id", col("emp_id").cast("long")))
# Convert multiple columns into different datatypes
display(df.withColumn("salary", col("salary").cast("float")).withColumn("age", col("age").cast("string")))
     
